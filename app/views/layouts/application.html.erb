<!DOCTYPE html>
<html lang="en" class="dark" data-controller="theme">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= display_meta_tags(site: "Oluwadare Juwon", separator: "|", reverse: true) %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-surface-950 text-surface-200 min-h-screen antialiased font-sans"
        data-theme-target="body"
        data-controller="turbo-transitions code-rain">

    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-primary-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
      Skip to content
    </a>

    <!-- Navigation -->
    <%= render "shared/navbar" %>

    <!-- Flash messages -->
    <% if notice %>
      <div class="fixed top-24 right-6 z-50 animate-slide-down" data-controller="toast" data-toast-delay-value="5000">
        <div class="bg-surface-950 border border-emerald-500/20 rounded-2xl px-5 py-3.5 text-sm text-emerald-300 flex items-center gap-3 shadow-2xl shadow-black/50">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>
          <%= notice %>
          <button data-action="toast#dismiss" class="ml-2 text-surface-500 hover:text-white transition-colors">&times;</button>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="fixed top-24 right-6 z-50 animate-slide-down" data-controller="toast" data-toast-delay-value="5000">
        <div class="bg-surface-950 border border-red-500/20 rounded-2xl px-5 py-3.5 text-sm text-red-300 flex items-center gap-3 shadow-2xl shadow-black/50">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= alert %>
          <button data-action="toast#dismiss" class="ml-2 text-surface-500 hover:text-white transition-colors">&times;</button>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main id="main-content" class="relative z-10">
      <%= yield %>
    </main>

    <!-- Footer -->
    <div class="relative z-10">
      <%= render "shared/footer" %>
    </div>

    <!-- Command Palette -->
    <%= render "shared/command_palette" %>
  </body>
</html>
