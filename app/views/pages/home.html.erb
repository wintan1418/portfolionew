<% content_for :head do %>
  <%= json_ld_tag({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": @profile.full_name,
    "jobTitle": "Full-Stack Software Engineer",
    "description": @profile.bio,
    "url": root_url,
    "sameAs": [@profile.github_url, @profile.linkedin_url, @profile.twitter_url].compact_blank,
    "address": { "@type": "PostalAddress", "addressCountry": @profile.location }
  }) %>
<% end %>

<!-- ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ -->
<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-1/3 right-[10%] w-[500px] h-[500px] bg-primary-500/10 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-[5%] w-[400px] h-[400px] bg-accent-500/8 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-surface-700 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-screen py-32">

      <!-- Left: Text -->
      <div class="order-2 lg:order-1">
        <% if @profile.available_for_hire? %>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 text-xs font-mono text-emerald-400 mb-8 animate-fade-in tracking-wider uppercase">
            <span class="relative flex h-1.5 w-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
            </span>
            <%= @profile.availability_text || "Available for hire" %>
          </div>
        <% end %>

        <p class="text-sm font-mono text-primary-400 mb-4 animate-fade-in-up" style="animation-delay: 0.05s; opacity: 0;">
          Hello, I'm
        </p>

        <h1 class="animate-fade-in-up" style="animation-delay: 0.15s; opacity: 0;">
          <span class="block text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight">
            Oluwadare
          </span>
          <span class="block text-5xl sm:text-6xl lg:text-7xl font-extrabold gradient-text leading-[1.05] tracking-tight mt-1">
            Juwon.
          </span>
        </h1>

        <div class="mt-6 text-xl sm:text-2xl text-surface-400 font-light animate-fade-in-up" style="animation-delay: 0.3s; opacity: 0;"
             data-controller="typing"
             data-typing-strings-value='["Software Engineer", "Ruby on Rails Expert", "AI Enthusiast", "Creator of RezumFit"]'
             data-typing-type-speed-value="70"
             data-typing-back-speed-value="35"
             data-typing-pause-value="2500">
          <span data-typing-target="output"></span>
          <span class="animate-blink text-primary-500 font-light">|</span>
        </div>

        <p class="mt-6 max-w-lg text-surface-400 leading-relaxed animate-fade-in-up" style="animation-delay: 0.45s; opacity: 0;">
          <%= @profile.bio %>
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap items-center gap-4 animate-fade-in-up" style="animation-delay: 0.6s; opacity: 0;">
          <%= link_to projects_path, class: "group inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-primary-600 text-white font-medium text-sm hover:bg-primary-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-primary-600/20" do %>
            View My Work
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          <% end %>
          <%= link_to contact_path, class: "inline-flex items-center gap-2 px-6 py-3.5 rounded-full border border-surface-700 text-white font-medium text-sm hover:border-surface-500 hover:bg-surface-900 transition-all" do %>
            Let's Talk
          <% end %>
        </div>

        <!-- Social links row -->
        <div class="mt-10 flex items-center gap-5 animate-fade-in-up" style="animation-delay: 0.75s; opacity: 0;">
          <a href="<%= @profile.github_url %>" target="_blank" rel="noopener" class="text-surface-500 hover:text-white transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="<%= @profile.linkedin_url %>" target="_blank" rel="noopener" class="text-surface-500 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="<%= @profile.twitter_url %>" target="_blank" rel="noopener" class="text-surface-500 hover:text-white transition-colors" aria-label="Twitter/X">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <div class="w-px h-4 bg-surface-800"></div>
          <span class="text-xs font-mono text-surface-500"><%= @profile.email %></span>
        </div>
      </div>

      <!-- Right: Photo -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end animate-fade-in" style="animation-delay: 0.3s; opacity: 0;">
        <div class="relative">
          <!-- Decorative elements -->
          <div class="absolute -top-4 -right-4 w-24 h-24 border border-primary-500/20 rounded-2xl animate-float" style="animation-delay: 1s;"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 border border-primary-500/10 rounded-full animate-float" style="animation-delay: 2s;"></div>
          <div class="absolute top-1/2 -right-8 w-2 h-2 bg-primary-500 rounded-full animate-pulse-glow"></div>
          <div class="absolute -bottom-2 left-1/4 w-1.5 h-1.5 bg-accent-500 rounded-full animate-pulse-glow" style="animation-delay: 1.5s;"></div>

          <!-- Photo container -->
          <div class="relative w-72 h-80 sm:w-80 sm:h-[400px] lg:w-96 lg:h-[480px] rounded-3xl overflow-hidden animate-border-glow border-2 border-primary-500/20 photo-glow">
            <img src="/images/juwon.jpg" alt="<%= @profile.full_name %>" class="w-full h-full object-cover object-top">
            <!-- Subtle gradient overlay at bottom -->
            <div class="absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-surface-950/60 to-transparent"></div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-3 -right-3 sm:bottom-4 sm:-right-6 glass rounded-2xl px-4 py-3 animate-fade-in-up" style="animation-delay: 1s; opacity: 0;">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-primary-600/20 flex items-center justify-center">
                <span class="text-primary-400 text-lg font-bold">6+</span>
              </div>
              <div>
                <p class="text-white text-sm font-semibold">Years</p>
                <p class="text-surface-500 text-[11px]">Experience</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════ STATS TICKER ═══════════════════════════════════════ -->
<section class="py-16 border-y border-surface-900" data-controller="scroll-reveal">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      <div class="reveal" data-controller="animate-counter" data-animate-counter-target-value="6" data-animate-counter-suffix-value="+">
        <div class="text-4xl font-extrabold text-white" data-animate-counter-target="number">0</div>
        <div class="mt-1 text-xs font-mono text-surface-500 uppercase tracking-wider">Years Experience</div>
      </div>
      <div class="reveal" data-controller="animate-counter" data-animate-counter-target-value="164">
        <div class="text-4xl font-extrabold text-white" data-animate-counter-target="number">0</div>
        <div class="mt-1 text-xs font-mono text-surface-500 uppercase tracking-wider">GitHub Repos</div>
      </div>
      <div class="reveal" data-controller="animate-counter" data-animate-counter-target-value="105">
        <div class="text-4xl font-extrabold text-white" data-animate-counter-target="number">0</div>
        <div class="mt-1 text-xs font-mono text-surface-500 uppercase tracking-wider">GitHub Stars</div>
      </div>
      <div class="reveal" data-controller="animate-counter" data-animate-counter-target-value="50" data-animate-counter-suffix-value="+">
        <div class="text-4xl font-extrabold text-white" data-animate-counter-target="number">0</div>
        <div class="mt-1 text-xs font-mono text-surface-500 uppercase tracking-wider">Projects Built</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════ FEATURED PROJECTS ═══════════════════════════════════ -->
<section class="py-24" data-controller="scroll-reveal">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Portfolio</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white reveal section-line">Featured Work</h2>
      </div>
      <div class="reveal">
        <%= link_to projects_path, class: "group hidden sm:inline-flex items-center gap-2 text-sm text-surface-400 hover:text-white transition-colors" do %>
          All Projects
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>
    </div>

    <% if @featured_projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <% @featured_projects.each do |project| %>
          <div class="reveal">
            <%= render "components/project_card", project: project %>
          </div>
        <% end %>
      </div>
      <div class="text-center mt-10 sm:hidden reveal">
        <%= link_to projects_path, class: "inline-flex items-center gap-2 text-sm text-primary-400 hover:text-primary-300 transition-colors" do %>
          View All Projects
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- ═══════════════════════════════════════ SKILLS ═══════════════════════════════════════ -->
<% if @skills.any? %>
<section class="py-24 " data-controller="scroll-reveal tabs">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Expertise</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white reveal section-line-center">Skills & Technologies</h2>
    </div>

    <!-- Category tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-10 reveal">
      <% @skills.keys.each_with_index do |category, i| %>
        <button data-tabs-target="tab" data-tab="<%= category %>" data-action="tabs#switch"
                class="px-5 py-2 rounded-full text-sm font-medium transition-all border <%= i == 0 ? 'text-white bg-primary-600/15 border-primary-500/40' : 'text-surface-500 border-surface-800 hover:text-white hover:border-surface-600' %>">
          <%= category || "Other" %>
        </button>
      <% end %>
    </div>

    <!-- Skill panels -->
    <% @skills.each_with_index do |(category, skills), i| %>
      <div data-tabs-target="panel" data-tab="<%= category %>" class="<%= 'hidden' unless i == 0 %>">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-4xl mx-auto">
          <% skills.each do |skill| %>
            <div class="group glass-hover rounded-xl p-4 reveal">
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-medium text-white"><%= skill.name %></span>
                <span class="text-xs font-mono text-primary-400"><%= skill.proficiency %>%</span>
              </div>
              <div class="w-full bg-surface-800 rounded-full h-1">
                <div class="bg-gradient-to-r from-primary-500 to-primary-400 h-1 rounded-full transition-all duration-1000" style="width: <%= skill.proficiency %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<!-- ═══════════════════════════════════════ EXPERIENCE ═══════════════════════════════════════ -->
<% if @experiences.any? %>
<section class="py-24 " data-controller="scroll-reveal">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Career</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white reveal section-line">Experience</h2>
      </div>
      <div class="reveal">
        <%= link_to experience_path, class: "group hidden sm:inline-flex items-center gap-2 text-sm text-surface-400 hover:text-white transition-colors" do %>
          Full Timeline
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>
    </div>

    <div class="max-w-3xl space-y-5">
      <% @experiences.each do |exp| %>
        <div class="group glass-hover rounded-2xl p-6 reveal">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-white"><%= exp.role %></h3>
              <p class="text-primary-400 text-sm font-medium"><%= exp.company %></p>
              <p class="text-surface-500 text-xs font-mono mt-2 uppercase tracking-wider">
                <%= exp.start_date.strftime("%b %Y") %> — <%= exp.current? ? "Present" : exp.end_date&.strftime("%b %Y") %>
                <% if exp.location.present? %> &middot; <%= exp.location %><% end %>
              </p>
            </div>
            <% if exp.current? %>
              <span class="flex-shrink-0 px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-mono uppercase tracking-wider border border-emerald-500/20">Current</span>
            <% end %>
          </div>
          <% if exp.description.present? %>
            <p class="mt-4 text-surface-400 text-sm leading-relaxed"><%= exp.description %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- ═══════════════════════════════════════ TESTIMONIALS ═══════════════════════════════════════ -->
<% if @testimonials.any? %>
<section class="py-24 " data-controller="scroll-reveal">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Feedback</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white reveal section-line-center">What People Say</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% @testimonials.each do |testimonial| %>
        <div class="glass-hover rounded-2xl p-6 reveal">
          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-5">
            <% (testimonial.rating || 5).times do %>
              <svg class="w-3.5 h-3.5 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <% end %>
          </div>

          <p class="text-surface-300 text-sm leading-relaxed">"<%= testimonial.content %>"</p>

          <div class="mt-6 flex items-center gap-3 pt-5 border-t border-surface-800/50">
            <% if testimonial.author_avatar.attached? %>
              <%= image_tag testimonial.author_avatar, class: "w-9 h-9 rounded-full object-cover" %>
            <% else %>
              <div class="w-9 h-9 rounded-full bg-surface-800 flex items-center justify-center text-surface-400 text-xs font-bold">
                <%= testimonial.author_name&.first %>
              </div>
            <% end %>
            <div>
              <p class="text-sm font-medium text-white"><%= testimonial.author_name %></p>
              <p class="text-[11px] text-surface-500"><%= testimonial.author_title %><%= ", #{testimonial.company}" if testimonial.company.present? %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- ═══════════════════════════════════════ NEWSLETTER ═══════════════════════════════════════ -->
<section class="py-24 " data-controller="scroll-reveal">
  <div class="max-w-xl mx-auto px-6 lg:px-8 text-center">
    <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Stay Updated</p>
    <h2 class="text-2xl font-extrabold text-white reveal">Get notified about new posts</h2>
    <p class="mt-3 text-surface-500 text-sm reveal">No spam. Unsubscribe anytime.</p>
    <form action="/subscribe" method="post" class="mt-8 flex flex-col sm:flex-row gap-3 reveal" data-turbo="true">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <input type="email" name="subscriber[email]" placeholder="your@email.com" required
             class="flex-1 px-5 py-3 rounded-full bg-surface-900 border border-surface-800 text-white placeholder-surface-600 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/30 text-sm">
      <button type="submit" class="px-6 py-3 rounded-full bg-primary-600 text-white font-medium text-sm hover:bg-primary-500 transition-colors whitespace-nowrap">
        Subscribe
      </button>
    </form>
  </div>
</section>

<!-- ═══════════════════════════════════════ CONTACT CTA ═══════════════════════════════════════ -->
<section class="py-24 " data-controller="scroll-reveal">
  <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
    <div class="reveal">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3">Get in Touch</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Have a project in mind?</h2>
      <p class="mt-4 text-surface-400">I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.</p>
      <div class="mt-10">
        <%= link_to contact_path, class: "group inline-flex items-center gap-3 px-8 py-4 rounded-full bg-white text-black font-semibold hover:bg-surface-100 transition-all hover:-translate-y-0.5 shadow-2xl shadow-white/5" do %>
          Let's Work Together
          <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>
    </div>
  </div>
</section>
