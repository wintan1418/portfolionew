<section class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in-up">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3">Blog</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white section-line-center">Thoughts & Writing</h1>
      <p class="mt-4 text-base text-surface-500">
        Thoughts on technology, engineering, and building products
      </p>
    </div>

    <!-- Search & Category Filters -->
    <div class="mb-10 animate-fade-in-up" style="animation-delay: 0.2s; opacity: 0;" data-controller="search">
      <!-- Search bar -->
      <div class="max-w-md mx-auto mb-6">
        <%= form_with url: blog_path, method: :get, data: { turbo_frame: "posts", search_target: "form" } do |f| %>
          <% if params[:category].present? %>
            <%= hidden_field_tag :category, params[:category] %>
          <% end %>
          <div class="relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" name="search" value="<%= params[:search] %>" placeholder="Search posts..."
                   autocomplete="off"
                   class="w-full rounded-full bg-surface-900 border border-surface-800 text-white px-4 py-2 text-sm pl-11 focus:outline-none focus:border-primary-500/50 focus:ring-1 focus:ring-primary-500/30 placeholder-surface-600"
                   data-search-target="input"
                   data-action="input->search#submit">
          </div>
        <% end %>
      </div>

      <!-- Category filter pills -->
      <% if @categories.any? %>
        <div class="flex flex-wrap justify-center gap-2">
          <%= link_to "All", blog_path(search: params[:search].presence),
              data: { turbo_frame: "posts" },
              class: "px-3 py-1 rounded-full text-xs font-mono transition-colors #{!@category ? 'bg-primary-600 text-white' : 'bg-surface-900 text-surface-400 hover:text-white'}" %>
          <% @categories.each do |cat| %>
            <%= link_to cat.name, blog_path(category: cat.slug, search: params[:search].presence),
                data: { turbo_frame: "posts" },
                class: "px-3 py-1 rounded-full text-xs font-mono transition-colors #{@category&.id == cat.id ? 'bg-primary-600 text-white' : 'bg-surface-900 text-surface-400 hover:text-white'}" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%= turbo_frame_tag "posts" do %>
      <!-- Featured Post -->
      <% if defined?(@featured_post) && @featured_post && !@category %>
        <div class="mb-12 animate-fade-in-up" style="animation-delay: 0.4s; opacity: 0;">
          <%= link_to blog_post_path(@featured_post.slug), class: "block glass-hover rounded-2xl overflow-hidden group transition-all" do %>
            <div class="grid grid-cols-1 md:grid-cols-2">
              <div class="aspect-video md:aspect-auto bg-surface-900 overflow-hidden">
                <% if @featured_post.cover_image.attached? %>
                  <%= image_tag @featured_post.cover_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %>
                <% else %>
                  <div class="w-full h-full min-h-[200px] flex items-center justify-center bg-gradient-to-br from-primary-950/80 to-surface-950">
                    <span class="text-6xl font-extrabold text-primary-500/10 select-none"><%= @featured_post.title.first(2).upcase %></span>
                  </div>
                <% end %>
              </div>
              <div class="p-8 flex flex-col justify-center">
                <div class="flex items-center gap-2 mb-3">
                  <span class="px-2.5 py-0.5 rounded-full bg-primary-600/20 text-primary-400 text-xs font-mono uppercase tracking-wider">Featured</span>
                  <% if @featured_post.category %>
                    <span class="text-xs font-mono text-surface-500 uppercase tracking-wider"><%= @featured_post.category.name %></span>
                  <% end %>
                </div>
                <h2 class="text-2xl font-bold text-white group-hover:text-primary-400 transition-colors"><%= @featured_post.title %></h2>
                <% if @featured_post.excerpt.present? %>
                  <p class="mt-3 text-surface-400 text-sm line-clamp-3"><%= @featured_post.excerpt %></p>
                <% end %>
                <div class="mt-4 flex items-center gap-3 text-xs font-mono text-surface-500 uppercase tracking-wider">
                  <span><%= @featured_post.published_at&.strftime("%B %d, %Y") %></span>
                  <% if @featured_post.reading_time %>
                    <span>&middot; <%= @featured_post.reading_time %> min read</span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Posts Grid -->
      <% if @posts.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-controller="scroll-reveal">
          <% @posts.each do |post| %>
            <div class="reveal">
              <%= render "components/blog_card", post: post %>
            </div>
          <% end %>
        </div>

        <!-- Pagination -->
        <% if @pagy.pages > 1 %>
          <div class="mt-12 flex justify-center">
            <%== pagy_nav(@pagy) %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center glass-hover rounded-2xl p-12">
          <p class="text-surface-500">
            <% if params[:search].present? || params[:category].present? %>
              No posts found matching your criteria. Try a different search or category.
            <% else %>
              No posts yet. Check back soon!
            <% end %>
          </p>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
