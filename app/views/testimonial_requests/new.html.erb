<section class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in-up">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3">Testimonial</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white section-line-center">Share Your Experience</h1>
      <p class="mt-4 text-base text-surface-500">
        Your feedback means a lot. Please take a moment to share your experience.
      </p>
    </div>

    <div class="max-w-2xl mx-auto animate-fade-in-up" style="animation-delay: 0.3s; opacity: 0;">
      <% if @testimonial.submitted_at.present? %>
        <div class="glass-hover rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-white mb-2">Thank You!</h2>
          <p class="text-surface-400">Your testimonial has been submitted and will be reviewed shortly.</p>
        </div>
      <% else %>
        <div class="glass-hover rounded-2xl p-8">
          <%= form_with(model: @testimonial, url: testimonial_request_path(token: @testimonial.token), method: :patch, class: "space-y-5") do |f| %>
            <% if @testimonial.errors.any? %>
              <div class="bg-red-500/10 border border-red-500/20 text-red-300 px-4 py-3 rounded-2xl text-sm">
                <ul class="list-disc list-inside space-y-1">
                  <% @testimonial.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <%= f.label :author_name, "Your Name", class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
                <%= f.text_field :author_name, required: true, placeholder: "Your full name", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
              </div>
              <div>
                <%= f.label :author_title, "Your Role/Title", class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
                <%= f.text_field :author_title, placeholder: "e.g. CTO, Product Manager", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
              </div>
            </div>

            <div>
              <%= f.label :company, class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
              <%= f.text_field :company, placeholder: "Your company name", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
            </div>

            <div>
              <%= f.label :content, "Your Testimonial", class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
              <%= f.text_area :content, required: true, rows: 5, placeholder: "Share your experience working together...", class: "w-full px-4 py-2.5 rounded-2xl bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 resize-none" %>
            </div>

            <div>
              <%= f.label :rating, class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
              <%= f.select :rating, options_for_select([["Select a rating", ""], ["5 - Excellent", 5], ["4 - Very Good", 4], ["3 - Good", 3], ["2 - Fair", 2], ["1 - Poor", 1]]), {}, class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
            </div>

            <%= f.submit "Submit Testimonial", class: "w-full py-3 rounded-full bg-primary-600 text-white font-medium hover:bg-primary-500 transition-colors cursor-pointer text-sm" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
