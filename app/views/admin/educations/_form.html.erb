<%= render "admin/shared/form_errors", resource: education %>

<%= form_with(model: education, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div>
      <%= f.label :institution, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :institution, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :degree, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :degree, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :field_of_study, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :field_of_study, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :start_date, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.date_field :start_date, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :end_date, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.date_field :end_date, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :position, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.number_field :position, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit education.new_record? ? "Create Education" : "Update Education", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_educations_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
