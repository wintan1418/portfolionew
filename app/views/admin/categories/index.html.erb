<% content_for(:page_title) { "Categories" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Categories</h2>
  <%= link_to "New Category", new_admin_category_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @categories.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Name</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Slug</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Color</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Posts</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= category.name %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= category.slug %></td>
            <td class="px-6 py-4 text-sm">
              <div class="flex items-center gap-2">
                <span class="inline-block w-4 h-4 rounded-full" style="background-color: <%= category.color %>"></span>
                <span class="text-surface-400 text-xs"><%= category.color %></span>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= category.posts.count %></td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Edit", edit_admin_category_path(category), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_category_path(category), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No categories yet.</p>
    </div>
  <% end %>
</div>
