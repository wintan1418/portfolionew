<%= render "admin/shared/form_errors", resource: category %>

<%= form_with(model: category, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :slug, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :slug, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500", placeholder: "Leave blank to auto-generate" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :color, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.color_field :color, class: "w-full h-10 px-1 py-1 rounded-lg bg-surface-800 border border-surface-700 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 cursor-pointer" %>
      </div>

      <div>
        <%= f.label :position, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.number_field :position, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit category.new_record? ? "Create Category" : "Update Category", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_categories_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
