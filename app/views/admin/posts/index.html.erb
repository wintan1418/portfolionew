<% content_for(:page_title) { "Posts" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Posts</h2>
  <%= link_to "New Post", new_admin_post_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @posts.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Title</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Status</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Category</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Published At</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Featured</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @posts.each do |post| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= post.title %></td>
            <td class="px-6 py-4 text-sm">
              <% if post.status == "published" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Published</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-500/20 text-yellow-300">Draft</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= post.category&.name %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= post.published_at&.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-sm">
              <% if post.featured? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary-500/20 text-primary-300">Featured</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm">
              <div class="flex items-center gap-3">
                <%= link_to "Edit", edit_admin_post_path(post), class: "text-primary-400 hover:text-primary-300 text-sm" %>
                <% if post.status == "draft" %>
                  <%= button_to "Publish", publish_admin_post_path(post), method: :patch, class: "text-green-400 hover:text-green-300 text-sm" %>
                <% else %>
                  <%= button_to "Unpublish", unpublish_admin_post_path(post), method: :patch, class: "text-yellow-400 hover:text-yellow-300 text-sm" %>
                <% end %>
                <%= button_to "Delete", admin_post_path(post), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No posts yet.</p>
    </div>
  <% end %>
</div>
