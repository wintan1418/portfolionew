<%= render "admin/shared/form_errors", resource: post %>

<%= form_with(model: post, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :title, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :slug, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :slug, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500", placeholder: "Leave blank to auto-generate" %>
    </div>

    <div>
      <%= f.label :excerpt, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :excerpt, rows: 3, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :category_id, "Category", class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.collection_select :category_id, Category.all, :id, :name, { include_blank: "No category" }, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :status, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.select :status, [["Draft", "draft"], ["Published", "published"]], {}, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="flex items-center">
      <%= f.check_box :featured, class: "rounded border-surface-700 bg-surface-800 text-primary-600 focus:ring-primary-500 mr-2" %>
      <%= f.label :featured, "Featured post", class: "text-sm text-surface-300" %>
    </div>

    <div>
      <%= f.label :cover_image, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <% if post.cover_image.attached? %>
        <div class="mb-2">
          <%= image_tag post.cover_image, class: "h-20 rounded-lg object-cover" %>
        </div>
      <% end %>
      <%= f.file_field :cover_image, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-sm file:bg-surface-700 file:text-surface-300" %>
    </div>

    <div>
      <%= f.label :body, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.rich_text_area :body, class: "w-full rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </div>

  <div class="glass rounded-xl p-6 space-y-5">
    <h3 class="text-sm font-medium text-surface-300">SEO Settings</h3>

    <div>
      <%= f.label :meta_title, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :meta_title, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :meta_description, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :meta_description, rows: 2, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit post.new_record? ? "Create Post" : "Update Post", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_posts_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
