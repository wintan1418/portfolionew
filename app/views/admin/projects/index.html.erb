<% content_for(:page_title) { "Projects" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Projects</h2>
  <%= link_to "New Project", new_admin_project_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @projects.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Title</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Status</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Type</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Featured</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Tech Stack</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= project.title %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= project.status&.humanize %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= project.project_type&.humanize %></td>
            <td class="px-6 py-4 text-sm">
              <% if project.featured? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary-500/20 text-primary-300">Featured</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300">
              <% Array(project.tech_stack).first(3).each do |tech| %>
                <span class="inline-block px-2 py-0.5 rounded bg-surface-800 text-surface-300 text-xs mr-1 mb-1"><%= tech %></span>
              <% end %>
              <% if Array(project.tech_stack).size > 3 %>
                <span class="text-xs text-surface-500">+<%= Array(project.tech_stack).size - 3 %> more</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Edit", edit_admin_project_path(project), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_project_path(project), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No projects yet.</p>
    </div>
  <% end %>
</div>
