<% content_for(:page_title) { "Subscribers" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Subscribers</h2>
  <%= button_to "Export CSV", export_admin_subscribers_path, method: :post, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @subscribers.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Email</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Name</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Status</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Subscribed At</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @subscribers.each do |subscriber| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= subscriber.email %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= subscriber.name %></td>
            <td class="px-6 py-4 text-sm">
              <% if subscriber.status == "active" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Active</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-surface-700 text-surface-400"><%= subscriber.status&.humanize %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= subscriber.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-sm">
              <%= button_to "Delete", admin_subscriber_path(subscriber), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No subscribers yet.</p>
    </div>
  <% end %>
</div>
