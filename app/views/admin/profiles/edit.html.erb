<% content_for(:page_title) { "Edit Profile" } %>

<%= form_with(model: @profile, url: admin_profile_path, class: "space-y-8 max-w-3xl") do |f| %>
  <% if @profile.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 text-red-300 px-4 py-3 rounded-lg text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% @profile.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Personal Info -->
  <fieldset class="glass rounded-xl p-6 space-y-4">
    <legend class="text-lg font-semibold text-white px-2">Personal Information</legend>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :first_name, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :first_name, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
      <div>
        <%= f.label :last_name, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :last_name, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div>
      <%= f.label :headline, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :headline, placeholder: "e.g. Full-Stack Software Engineer", class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :bio, "Short Bio (for hero section)", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :bio, rows: 3, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :about, "About (longer bio)", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :about, rows: 6, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :location, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :location, placeholder: "e.g. Lagos, Nigeria", class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </fieldset>

  <!-- Contact Info -->
  <fieldset class="glass rounded-xl p-6 space-y-4">
    <legend class="text-lg font-semibold text-white px-2">Contact</legend>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.email_field :email, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
      <div>
        <%= f.label :phone, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :phone, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>
  </fieldset>

  <!-- Social Links -->
  <fieldset class="glass rounded-xl p-6 space-y-4">
    <legend class="text-lg font-semibold text-white px-2">Social Links</legend>

    <div>
      <%= f.label :github_url, "GitHub URL", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.url_field :github_url, placeholder: "https://github.com/username", class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
    <div>
      <%= f.label :linkedin_url, "LinkedIn URL", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.url_field :linkedin_url, placeholder: "https://linkedin.com/in/username", class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
    <div>
      <%= f.label :twitter_url, "Twitter/X URL", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.url_field :twitter_url, placeholder: "https://twitter.com/username", class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </fieldset>

  <!-- Availability -->
  <fieldset class="glass rounded-xl p-6 space-y-4">
    <legend class="text-lg font-semibold text-white px-2">Availability</legend>

    <div class="flex items-center gap-3">
      <%= f.check_box :available_for_hire, class: "w-4 h-4 rounded bg-surface-800 border-surface-600 text-primary-500 focus:ring-primary-500" %>
      <%= f.label :available_for_hire, "Available for hire", class: "text-sm text-surface-300" %>
    </div>

    <div>
      <%= f.label :availability_text, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :availability_text, placeholder: "e.g. Available for freelance work", class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </fieldset>

  <!-- Avatar & Resume -->
  <fieldset class="glass rounded-xl p-6 space-y-4">
    <legend class="text-lg font-semibold text-white px-2">Files</legend>

    <div>
      <%= f.label :avatar, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <% if @profile.avatar.attached? %>
        <div class="mb-2">
          <%= image_tag @profile.avatar, class: "w-20 h-20 rounded-lg object-cover" %>
        </div>
      <% end %>
      <%= f.file_field :avatar, accept: "image/*", class: "text-sm text-surface-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary-600 file:text-white hover:file:bg-primary-500" %>
    </div>

    <div>
      <%= f.label :resume_pdf, "Resume PDF", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <% if @profile.resume_pdf.attached? %>
        <p class="text-xs text-emerald-400 mb-2">Resume uploaded: <%= @profile.resume_pdf.filename %></p>
      <% end %>
      <%= f.file_field :resume_pdf, accept: ".pdf", class: "text-sm text-surface-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary-600 file:text-white hover:file:bg-primary-500" %>
    </div>
  </fieldset>

  <!-- SEO -->
  <fieldset class="glass rounded-xl p-6 space-y-4">
    <legend class="text-lg font-semibold text-white px-2">SEO</legend>

    <div>
      <%= f.label :meta_description, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :meta_description, rows: 2, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :og_title, "Open Graph Title", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :og_title, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>
  </fieldset>

  <!-- Submit -->
  <div class="flex items-center gap-4">
    <%= f.submit "Save Profile", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_root_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
