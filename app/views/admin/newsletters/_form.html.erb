<%= render "admin/shared/form_errors", resource: newsletter %>

<%= form_with(model: newsletter, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div>
      <%= f.label :subject, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :subject, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500", placeholder: "Newsletter subject line" %>
    </div>

    <div>
      <%= f.label :body, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :body, rows: 12, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500", placeholder: "Write your newsletter content here..." %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit newsletter.new_record? ? "Create Newsletter" : "Update Newsletter", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_newsletters_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
