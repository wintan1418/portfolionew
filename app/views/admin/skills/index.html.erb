<% content_for(:page_title) { "Skills" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Skills</h2>
  <%= link_to "New Skill", new_admin_skill_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @skills.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Name</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Category</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Proficiency</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Featured</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @skills.each do |skill| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= skill.name %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= skill.category %></td>
            <td class="px-6 py-4 text-sm">
              <div class="flex items-center gap-3">
                <div class="w-24 h-2 rounded-full bg-surface-800 overflow-hidden">
                  <div class="h-full rounded-full bg-primary-500" style="width: <%= skill.proficiency %>%"></div>
                </div>
                <span class="text-surface-400 text-xs"><%= skill.proficiency %>%</span>
              </div>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if skill.featured? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary-500/20 text-primary-300">Featured</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Edit", edit_admin_skill_path(skill), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_skill_path(skill), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No skills yet.</p>
    </div>
  <% end %>
</div>
