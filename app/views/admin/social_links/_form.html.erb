<%= render "admin/shared/form_errors", resource: social_link %>

<%= form_with(model: social_link, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div>
      <%= f.label :platform, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.select :platform, [["GitHub", "github"], ["LinkedIn", "linkedin"], ["Twitter", "twitter"], ["YouTube", "youtube"], ["WhatsApp", "whatsapp"], ["Phone", "phone"], ["Email", "email"], ["Website", "website"], ["Other", "other"]], { include_blank: "Select platform" }, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :url, "URL / Number", class: "block text-sm font-medium text-surface-300 mb-1" %>
      <p class="text-xs text-surface-500 mb-1">For WhatsApp/Phone use: https://wa.me/2348012345678 or tel:+2348012345678</p>
      <%= f.text_field :url, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500", placeholder: "https:// or tel:+234..." %>
    </div>

    <div>
      <%= f.label :icon, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :icon, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500", placeholder: "e.g. fab fa-github" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :position, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.number_field :position, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div class="flex items-center pt-6">
        <%= f.check_box :visible, class: "rounded border-surface-700 bg-surface-800 text-primary-600 focus:ring-primary-500 mr-2" %>
        <%= f.label :visible, "Visible on site", class: "text-sm text-surface-300" %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit social_link.new_record? ? "Create Social Link" : "Update Social Link", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_social_links_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
