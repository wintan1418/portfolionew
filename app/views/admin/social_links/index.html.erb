<% content_for(:page_title) { "Social Links" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Social Links</h2>
  <%= link_to "New Social Link", new_admin_social_link_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @social_links.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Platform</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">URL</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Visible</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @social_links.each do |social_link| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= social_link.platform&.humanize %></td>
            <td class="px-6 py-4 text-sm text-surface-300 truncate max-w-xs">
              <%= link_to truncate(social_link.url, length: 40), social_link.url, target: "_blank", class: "text-primary-400 hover:text-primary-300" %>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if social_link.visible? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Visible</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-surface-700 text-surface-400">Hidden</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Edit", edit_admin_social_link_path(social_link), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_social_link_path(social_link), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No social links yet.</p>
    </div>
  <% end %>
</div>
