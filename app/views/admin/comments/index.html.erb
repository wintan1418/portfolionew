<% content_for(:page_title) { "Comments" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Comments</h2>
  <span class="text-sm text-surface-400"><%= @comments.count %> total</span>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @comments.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Author</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Comment</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Post</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Date</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @comments.each do |comment| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4">
              <div class="text-sm text-surface-100 font-medium"><%= comment.author_name %></div>
              <% if comment.author_email.present? %>
                <div class="text-xs text-surface-500"><%= comment.author_email %></div>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300 max-w-xs">
              <p class="truncate"><%= comment.body %></p>
              <% if comment.parent_id.present? %>
                <span class="text-xs text-primary-400">reply</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm">
              <%= link_to comment.post.title, blog_post_path(comment.post.slug), class: "text-primary-400 hover:text-primary-300 transition-colors", target: "_blank" %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= comment.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-sm">
              <%= button_to "Delete", admin_comment_path(comment), method: :delete, data: { turbo_confirm: "Delete this comment?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No comments yet.</p>
    </div>
  <% end %>
</div>
