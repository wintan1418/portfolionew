<% content_for(:page_title) { "Comments" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Comments</h2>
  <div class="flex items-center gap-2">
    <%= link_to "All", admin_comments_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{params[:status].blank? ? 'bg-primary-600 text-white' : 'text-surface-400 hover:text-white'}" %>
    <%= link_to "Pending", admin_comments_path(status: "pending"), class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{params[:status] == 'pending' ? 'bg-yellow-600 text-white' : 'text-surface-400 hover:text-white'}" %>
    <%= link_to "Approved", admin_comments_path(status: "approved"), class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{params[:status] == 'approved' ? 'bg-green-600 text-white' : 'text-surface-400 hover:text-white'}" %>
  </div>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @comments.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Author</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Comment</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Post</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Status</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Date</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @comments.each do |comment| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4">
              <div class="text-sm text-surface-100 font-medium"><%= comment.author_name %></div>
              <% if comment.author_email.present? %>
                <div class="text-xs text-surface-500"><%= comment.author_email %></div>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300 max-w-xs">
              <p class="truncate"><%= comment.body %></p>
              <% if comment.parent_id.present? %>
                <span class="text-xs text-primary-400">reply</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm">
              <%= link_to comment.post.title, blog_post_path(comment.post.slug), class: "text-primary-400 hover:text-primary-300 transition-colors", target: "_blank" %>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if comment.approved? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Approved</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-500/20 text-yellow-300">Pending</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= comment.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-sm">
              <div class="flex items-center gap-3">
                <% if comment.approved? %>
                  <%= button_to "Reject", reject_admin_comment_path(comment), method: :patch, class: "text-yellow-400 hover:text-yellow-300 text-sm" %>
                <% else %>
                  <%= button_to "Approve", approve_admin_comment_path(comment), method: :patch, class: "text-green-400 hover:text-green-300 text-sm" %>
                <% end %>
                <%= button_to "Delete", admin_comment_path(comment), method: :delete, data: { turbo_confirm: "Delete this comment?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No comments yet.</p>
    </div>
  <% end %>
</div>
