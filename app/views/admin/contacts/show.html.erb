<% content_for(:page_title) { "Contact from #{@contact.name}" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Contact Details</h2>
  <%= link_to "Back to Contacts", admin_contacts_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
</div>

<div class="glass rounded-xl p-6 max-w-3xl space-y-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Name</p>
      <p class="text-sm text-surface-100"><%= @contact.name %></p>
    </div>

    <div>
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Email</p>
      <p class="text-sm">
        <%= mail_to @contact.email, @contact.email, class: "text-primary-400 hover:text-primary-300" %>
      </p>
    </div>

    <% if @contact.phone.present? %>
      <div>
        <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Phone</p>
        <p class="text-sm text-surface-100"><%= @contact.phone %></p>
      </div>
    <% end %>

    <% if @contact.company.present? %>
      <div>
        <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Company</p>
        <p class="text-sm text-surface-100"><%= @contact.company %></p>
      </div>
    <% end %>

    <% if @contact.budget_range.present? %>
      <div>
        <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Budget Range</p>
        <p class="text-sm text-surface-100"><%= @contact.budget_range %></p>
      </div>
    <% end %>

    <div>
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Status</p>
      <p class="text-sm">
        <% case @contact.status %>
        <% when "unread" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-500/20 text-blue-300">Unread</span>
        <% when "read" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-surface-700 text-surface-400">Read</span>
        <% when "replied" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Replied</span>
        <% end %>
      </p>
    </div>

    <div>
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Received</p>
      <p class="text-sm text-surface-100"><%= @contact.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>
  </div>

  <% if @contact.subject.present? %>
    <div>
      <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Subject</p>
      <p class="text-sm text-surface-100"><%= @contact.subject %></p>
    </div>
  <% end %>

  <div>
    <p class="text-xs font-medium text-surface-500 uppercase tracking-wider mb-1">Message</p>
    <div class="text-sm text-surface-200 bg-surface-800/50 rounded-lg p-4 whitespace-pre-wrap"><%= @contact.message %></div>
  </div>

  <div class="flex items-center gap-3 pt-2 border-t border-surface-800">
    <% if @contact.status != "replied" %>
      <%= button_to "Mark as Replied", admin_contact_path(@contact), params: { contact: { status: "replied" } }, method: :patch, class: "px-4 py-2 rounded-lg bg-green-600 text-white text-sm font-medium hover:bg-green-500 transition-colors cursor-pointer" %>
    <% end %>
    <%= button_to "Delete", admin_contact_path(@contact), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "px-4 py-2 rounded-lg bg-red-600/20 text-red-400 text-sm font-medium hover:bg-red-600/30 transition-colors cursor-pointer" %>
  </div>
</div>
