<% content_for(:page_title) { "Contacts" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Contacts</h2>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @contacts.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Name</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Email</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Subject</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Status</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Received</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @contacts.each do |contact| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= contact.name %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= contact.email %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= truncate(contact.subject, length: 30) %></td>
            <td class="px-6 py-4 text-sm">
              <% case contact.status %>
              <% when "unread" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-500/20 text-blue-300">Unread</span>
              <% when "read" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-surface-700 text-surface-400">Read</span>
              <% when "replied" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Replied</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= contact.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Show", admin_contact_path(contact), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_contact_path(contact), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No contacts yet.</p>
    </div>
  <% end %>
</div>
