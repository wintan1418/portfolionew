<%= render "admin/shared/form_errors", resource: testimonial %>

<%= form_with(model: testimonial, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :author_name, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :author_name, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :author_title, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :author_title, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div>
      <%= f.label :company, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_field :company, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div>
      <%= f.label :content, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :content, rows: 4, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div>
        <%= f.label :rating, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.number_field :rating, in: 1..5, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :relationship, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.select :relationship, [["Client", "client"], ["Colleague", "colleague"], ["Manager", "manager"], ["Other", "other"]], { include_blank: "Select relationship" }, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :position, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.number_field :position, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="flex items-center">
      <%= f.check_box :featured, class: "rounded border-surface-700 bg-surface-800 text-primary-600 focus:ring-primary-500 mr-2" %>
      <%= f.label :featured, "Featured testimonial", class: "text-sm text-surface-300" %>
    </div>

    <div>
      <%= f.label :author_avatar, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <% if testimonial.author_avatar.attached? %>
        <div class="mb-2">
          <%= image_tag testimonial.author_avatar, class: "h-12 w-12 rounded-full object-cover" %>
        </div>
      <% end %>
      <%= f.file_field :author_avatar, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-sm file:bg-surface-700 file:text-surface-300" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit testimonial.new_record? ? "Create Testimonial" : "Update Testimonial", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_testimonials_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
