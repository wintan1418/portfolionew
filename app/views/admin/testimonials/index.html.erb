<% content_for(:page_title) { "Testimonials" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Testimonials</h2>
  <%= link_to "New Testimonial", new_admin_testimonial_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @testimonials.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Author</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Title</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Company</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Featured</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @testimonials.each do |testimonial| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= testimonial.author_name %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= testimonial.author_title %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= testimonial.company %></td>
            <td class="px-6 py-4 text-sm">
              <% if testimonial.featured? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary-500/20 text-primary-300">Featured</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Edit", edit_admin_testimonial_path(testimonial), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_testimonial_path(testimonial), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No testimonials yet.</p>
    </div>
  <% end %>
</div>
