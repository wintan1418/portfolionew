<% content_for(:page_title) { "Experiences" } %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-bold text-white">Experiences</h2>
  <%= link_to "New Experience", new_admin_experience_path, class: "px-4 py-2 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors" %>
</div>

<div class="glass rounded-xl overflow-hidden">
  <% if @experiences.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-surface-800">
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Company</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Role</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Dates</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Current</th>
          <th class="text-left text-xs font-medium text-surface-500 uppercase tracking-wider px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @experiences.each do |experience| %>
          <tr class="border-b border-surface-800">
            <td class="px-6 py-4 text-sm text-surface-100"><%= experience.company %></td>
            <td class="px-6 py-4 text-sm text-surface-300"><%= experience.role %></td>
            <td class="px-6 py-4 text-sm text-surface-300">
              <%= experience.start_date&.strftime("%b %Y") %> &mdash; <%= experience.end_date&.strftime("%b %Y") || "Present" %>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if experience.current? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/20 text-green-300">Current</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm space-x-3">
              <%= link_to "Edit", edit_admin_experience_path(experience), class: "text-primary-400 hover:text-primary-300 text-sm" %>
              <%= button_to "Delete", admin_experience_path(experience), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-surface-400">No experiences yet.</p>
    </div>
  <% end %>
</div>
