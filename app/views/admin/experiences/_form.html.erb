<%= render "admin/shared/form_errors", resource: experience %>

<%= form_with(model: experience, url: url, class: "space-y-6 max-w-3xl") do |f| %>
  <div class="glass rounded-xl p-6 space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :company, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :company, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :role, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :role, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :location, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.text_field :location, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :company_url, "Company URL", class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.url_field :company_url, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :start_date, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.date_field :start_date, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :end_date, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.date_field :end_date, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :employment_type, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.select :employment_type, [["Full Time", "full_time"], ["Contract", "contract"], ["Freelance", "freelance"], ["Internship", "internship"]], { include_blank: "Select type" }, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :position, class: "block text-sm font-medium text-surface-300 mb-1" %>
        <%= f.number_field :position, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="flex items-center">
      <%= f.check_box :current, class: "rounded border-surface-700 bg-surface-800 text-primary-600 focus:ring-primary-500 mr-2" %>
      <%= f.label :current, "Currently working here", class: "text-sm text-surface-300" %>
    </div>

    <div>
      <%= f.label :company_logo, class: "block text-sm font-medium text-surface-300 mb-1" %>
      <% if experience.company_logo.attached? %>
        <div class="mb-2">
          <%= image_tag experience.company_logo, class: "h-12 rounded-lg object-contain" %>
        </div>
      <% end %>
      <%= f.file_field :company_logo, class: "w-full px-3 py-2 rounded-lg bg-surface-800 border border-surface-700 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-sm file:bg-surface-700 file:text-surface-300" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit experience.new_record? ? "Create Experience" : "Update Experience", class: "px-6 py-2.5 rounded-lg bg-primary-600 text-white text-sm font-medium hover:bg-primary-500 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_experiences_path, class: "text-sm text-surface-400 hover:text-white transition-colors" %>
  </div>
<% end %>
