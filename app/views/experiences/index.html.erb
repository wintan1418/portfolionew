<section class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in-up">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3">Career</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white section-line-center">Experience</h1>
      <p class="mt-4 text-base text-surface-500">
        My professional journey
      </p>
    </div>

    <!-- Work Experience Timeline -->
    <% if @experiences.any? %>
      <div class="max-w-3xl mx-auto" data-controller="scroll-reveal">
        <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Timeline</p>
        <h2 class="text-3xl font-extrabold text-white section-line mb-8 reveal">Work Experience</h2>

        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-4 top-0 bottom-0 w-px bg-surface-900"></div>

          <div class="space-y-8">
            <% @experiences.each do |exp| %>
              <div class="relative pl-12 reveal">
                <!-- Timeline dot -->
                <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full border-2 <%= exp.current? ? 'bg-emerald-500 border-emerald-400' : 'bg-surface-800 border-surface-700' %>"></div>

                <div class="glass-hover rounded-2xl p-6">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                    <div>
                      <h3 class="text-lg font-semibold text-white"><%= exp.role %></h3>
                      <p class="text-primary-400 font-medium">
                        <% if exp.company_url.present? %>
                          <a href="<%= exp.company_url %>" target="_blank" rel="noopener" class="hover:text-primary-300 transition-colors"><%= exp.company %></a>
                        <% else %>
                          <%= exp.company %>
                        <% end %>
                      </p>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <span class="font-mono text-surface-500 text-xs uppercase tracking-wider">
                        <%= exp.start_date.strftime("%b %Y") %> — <%= exp.current? ? "Present" : exp.end_date&.strftime("%b %Y") %>
                      </span>
                      <% if exp.current? %>
                        <span class="px-2 py-0.5 rounded-full bg-emerald-500/20 text-emerald-400 text-xs font-mono">Current</span>
                      <% end %>
                    </div>
                  </div>

                  <% if exp.location.present? || exp.employment_type.present? %>
                    <div class="mt-2 flex items-center gap-3 text-xs font-mono text-surface-500 uppercase tracking-wider">
                      <% if exp.location.present? %>
                        <span class="flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                          <%= exp.location %>
                        </span>
                      <% end %>
                      <% if exp.employment_type.present? %>
                        <span class="capitalize"><%= exp.employment_type.gsub("_", " ") %></span>
                      <% end %>
                    </div>
                  <% end %>

                  <% if exp.description.present? %>
                    <p class="mt-3 text-surface-400 text-sm leading-relaxed"><%= exp.description %></p>
                  <% end %>

                  <% if exp.highlights.any? %>
                    <ul class="mt-3 space-y-1">
                      <% exp.highlights.each do |highlight| %>
                        <li class="text-surface-400 text-sm flex items-start gap-2">
                          <svg class="w-3.5 h-3.5 text-primary-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                          <%= highlight %>
                        </li>
                      <% end %>
                    </ul>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Education -->
    <% if @educations.any? %>
      <div class="max-w-3xl mx-auto mt-16" data-controller="scroll-reveal">
        <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3 reveal">Background</p>
        <h2 class="text-3xl font-extrabold text-white section-line mb-8 reveal">Education</h2>

        <div class="space-y-4">
          <% @educations.each do |edu| %>
            <div class="glass-hover rounded-2xl p-6 reveal">
              <h3 class="text-lg font-semibold text-white"><%= edu.institution %></h3>
              <% if edu.degree.present? || edu.field_of_study.present? %>
                <p class="text-primary-400 font-medium mt-1">
                  <%= [edu.degree, edu.field_of_study].compact.join(" in ") %>
                </p>
              <% end %>
              <% if edu.start_date.present? %>
                <p class="font-mono text-surface-500 text-xs uppercase tracking-wider mt-1">
                  <%= edu.start_date.strftime("%Y") %><%= " — #{edu.end_date.strftime('%Y')}" if edu.end_date.present? %>
                </p>
              <% end %>
              <% if edu.description.present? %>
                <p class="mt-3 text-surface-400 text-sm"><%= edu.description %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
