<section class="py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-fade-in-up">
      <div class="inline-flex w-16 h-16 rounded-full bg-emerald-500/10 items-center justify-center mb-6 border border-emerald-500/20">
        <svg class="w-8 h-8 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3">Message Sent</p>
      <h1 class="text-3xl font-extrabold text-white section-line-center">Thank You!</h1>
      <p class="mt-4 text-surface-500">Your message has been sent. I'll get back to you as soon as possible.</p>
      <%= link_to "Back to Home", root_path, class: "inline-block mt-8 px-6 py-3 rounded-full bg-primary-600 text-white font-medium hover:bg-primary-500 transition-colors" %>
    </div>
  </div>
</section>
