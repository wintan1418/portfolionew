<section class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in-up">
      <p class="text-xs font-mono text-primary-400 uppercase tracking-[0.2em] mb-3">Contact</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white section-line-center">Get in Touch</h1>
      <p class="mt-4 text-base text-surface-500">
        Have a project in mind? Let's talk.
      </p>
    </div>

    <div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Contact Form -->
      <div class="lg:col-span-3 animate-fade-in-up" style="animation-delay: 0.3s; opacity: 0;">
        <div class="glass-hover rounded-2xl p-8">
          <%= form_with(model: @contact, url: contact_path, class: "space-y-5") do |f| %>
            <% if @contact.errors.any? %>
              <div class="bg-red-500/10 border border-red-500/20 text-red-300 px-4 py-3 rounded-2xl text-sm">
                <ul class="list-disc list-inside space-y-1">
                  <% @contact.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <%= f.label :name, class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
                <%= f.text_field :name, required: true, placeholder: "Your name", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
              </div>
              <div>
                <%= f.label :email, class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
                <%= f.email_field :email, required: true, placeholder: "your@email.com", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <%= f.label :company, "Company (optional)", class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
                <%= f.text_field :company, placeholder: "Your company", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
              </div>
              <div>
                <%= f.label :budget_range, "Budget Range", class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
                <%= f.select :budget_range, options_for_select([["Select budget", ""], ["< $1,000", "< $1k"], ["$1,000 - $5,000", "$1k-$5k"], ["$5,000 - $10,000", "$5k-$10k"], ["$10,000+", "$10k+"], ["Not sure yet", "unsure"]]), {}, class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
              </div>
            </div>

            <div>
              <%= f.label :subject, class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
              <%= f.text_field :subject, placeholder: "What's this about?", class: "w-full px-4 py-2.5 rounded-full bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500" %>
            </div>

            <div>
              <%= f.label :message, class: "block text-xs font-mono text-surface-500 uppercase tracking-wider mb-2" %>
              <%= f.text_area :message, required: true, rows: 5, placeholder: "Tell me about your project...", class: "w-full px-4 py-2.5 rounded-2xl bg-surface-950 border border-surface-800 text-white text-sm placeholder-surface-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 resize-none" %>
            </div>

            <%= f.submit "Send Message", class: "w-full py-3 rounded-full bg-primary-600 text-white font-medium hover:bg-primary-500 transition-colors cursor-pointer text-sm" %>
          <% end %>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="lg:col-span-2 animate-fade-in-up" style="animation-delay: 0.5s; opacity: 0;">
        <!-- Availability -->
        <% if @profile.available_for_hire? %>
          <div class="glass-hover rounded-2xl p-6 mb-6">
            <div class="flex items-center gap-3">
              <span class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
              </span>
              <div>
                <p class="text-emerald-400 font-medium text-sm">Available for hire</p>
                <p class="text-xs font-mono text-surface-500 uppercase tracking-wider"><%= @profile.availability_text %></p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Direct Contact -->
        <div class="glass-hover rounded-2xl p-6 space-y-4">
          <h3 class="text-base font-semibold text-white">Direct Contact</h3>

          <% if @profile.email.present? %>
            <a href="mailto:<%= @profile.email %>" class="flex items-center gap-3 text-surface-400 hover:text-primary-400 transition-colors group">
              <div class="w-10 h-10 rounded-full bg-surface-900 flex items-center justify-center group-hover:bg-surface-800 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-xs font-mono text-surface-500 uppercase tracking-wider">Email</p>
                <p class="text-sm text-surface-400"><%= @profile.email %></p>
              </div>
            </a>
          <% end %>

          <% if @profile.location.present? %>
            <div class="flex items-center gap-3 text-surface-400">
              <div class="w-10 h-10 rounded-full bg-surface-900 flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              </div>
              <div>
                <p class="text-xs font-mono text-surface-500 uppercase tracking-wider">Location</p>
                <p class="text-sm text-surface-400"><%= @profile.location %></p>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Social Links -->
        <div class="glass-hover rounded-2xl p-6 mt-6">
          <h3 class="text-base font-semibold text-white mb-4">Connect</h3>
          <div class="flex items-center gap-3">
            <% if @profile.github_url.present? %>
              <a href="<%= @profile.github_url %>" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-surface-900 flex items-center justify-center text-surface-400 hover:text-white hover:bg-surface-800 transition-all" aria-label="GitHub">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
            <% end %>
            <% if @profile.linkedin_url.present? %>
              <a href="<%= @profile.linkedin_url %>" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-surface-900 flex items-center justify-center text-surface-400 hover:text-white hover:bg-surface-800 transition-all" aria-label="LinkedIn">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            <% end %>
            <% if @profile.twitter_url.present? %>
              <a href="<%= @profile.twitter_url %>" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-surface-900 flex items-center justify-center text-surface-400 hover:text-white hover:bg-surface-800 transition-all" aria-label="Twitter/X">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
