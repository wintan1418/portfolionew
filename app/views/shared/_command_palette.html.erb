<div data-controller="command-palette">
  <dialog data-command-palette-target="dialog"
          class="fixed inset-0 z-[100] bg-transparent backdrop:bg-black/70 backdrop:backdrop-blur-sm p-0 m-0 w-full h-full max-w-none max-h-none">
    <div class="flex items-start justify-center pt-[20vh] min-h-full" data-action="click->command-palette#closeOnBackdrop">
      <div class="w-full max-w-md bg-surface-950 border border-surface-800 rounded-2xl shadow-2xl shadow-black/50 overflow-hidden">
        <!-- Search Input -->
        <div class="flex items-center gap-3 px-5 border-b border-surface-900">
          <svg class="w-4 h-4 text-surface-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text"
                 data-command-palette-target="input"
                 data-action="input->command-palette#search keydown->command-palette#navigate"
                 placeholder="Type a command..."
                 class="w-full py-4 bg-transparent text-sm text-white placeholder-surface-600 outline-none"
                 autocomplete="off">
          <kbd class="text-[10px] text-surface-500 font-mono border border-surface-800 px-1.5 py-0.5 rounded">ESC</kbd>
        </div>

        <!-- Results -->
        <div data-command-palette-target="results" class="max-h-72 overflow-y-auto p-2">
          <div class="text-[10px] font-mono text-surface-500 uppercase tracking-[0.15em] px-3 py-2">Navigation</div>
          <%= command_palette_item("Home", root_path, "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6") %>
          <%= command_palette_item("About", about_path, "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z") %>
          <%= command_palette_item("Projects", projects_path, "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10") %>
          <%= command_palette_item("Blog", blog_path, "M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z") %>
          <%= command_palette_item("Experience", experience_path, "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z") %>
          <%= command_palette_item("Contact", contact_path, "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z") %>
        </div>
      </div>
    </div>
  </dialog>
</div>
