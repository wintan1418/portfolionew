<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
     data-controller="navbar"
     data-navbar-target="nav">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-3 group relative" do %>
        <div class="relative">
          <span class="text-lg font-extrabold text-white tracking-tight group-hover:text-primary-400 transition-colors">JUWON</span>
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-primary-500 to-accent-500 group-hover:w-full transition-all duration-300"></span>
        </div>
        <div class="hidden sm:flex items-center gap-2">
          <span class="w-1 h-1 rounded-full bg-primary-500"></span>
          <span class="text-[10px] font-mono text-surface-500 uppercase tracking-[0.2em]">Developer</span>
        </div>
        <% nav_profile = Profile.instance rescue nil %>
        <% if nav_profile&.available_for_hire %>
          <span class="hidden sm:inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-[10px] font-mono text-emerald-400 uppercase tracking-wider">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Available
          </span>
        <% end %>
      <% end %>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-1">
        <%= nav_link_pill "Home", root_path %>
        <%= nav_link_pill "About", about_path %>
        <%= nav_link_pill "Projects", projects_path %>
        <%= nav_link_pill "Services", services_path %>
        <%= nav_link_pill "Blog", blog_path %>
        <%= nav_link_pill "Contact", contact_path %>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-2">
        <!-- Theme toggle -->
        <button data-action="theme#toggle"
                data-theme-target="toggle"
                class="relative w-9 h-9 rounded-xl flex items-center justify-center text-surface-400 hover:text-white hover:bg-surface-800/50 transition-all duration-200"
                aria-label="Toggle theme">
          <svg class="w-4 h-4 dark-icon transition-transform duration-300 hover:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <svg class="w-4 h-4 light-icon hidden transition-transform duration-300 hover:-rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>

        <!-- Mobile toggle -->
        <button data-action="navbar#toggleMobile"
                data-navbar-target="menuButton"
                class="md:hidden w-9 h-9 rounded-xl flex items-center justify-center text-surface-400 hover:text-white hover:bg-surface-800/50 transition-all duration-200"
                aria-label="Toggle menu">
          <!-- Hamburger (shown when closed) -->
          <svg class="w-5 h-5 block" data-navbar-target="hamburgerIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <!-- Close X (shown when open) -->
          <svg class="w-5 h-5 hidden" data-navbar-target="closeIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden overflow-hidden transition-all duration-300 ease-out"
       data-navbar-target="mobileMenu"
       style="max-height: 0; opacity: 0;">
    <div class="bg-surface-950/98 backdrop-blur-2xl border-t border-surface-800/50 px-6 py-6 space-y-1">
      <%= mobile_nav_link "Home", root_path %>
      <%= mobile_nav_link "About", about_path %>
      <%= mobile_nav_link "Projects", projects_path %>
