<% profile = Profile.instance rescue nil %>
<% social_links = SocialLink.visible.ordered rescue [] %>

<footer class="relative mt-0">
  <!-- Gradient top border -->
  <div class="h-px bg-gradient-to-r from-transparent via-primary-500/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-16">

      <!-- Brand column -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-lg font-extrabold text-white tracking-tight"><%= profile&.last_name&.upcase || "JUWON" %></span>
          <span class="w-1 h-1 rounded-full bg-primary-500"></span>
          <span class="text-[10px] font-mono text-surface-500 uppercase tracking-[0.2em]"><%= profile&.headline&.split(' ')&.first || "Developer" %></span>
        </div>

        <p class="text-surface-400 text-sm leading-relaxed max-w-sm">
          <%= profile&.bio.presence || "Full-Stack Software Engineer crafting production-grade applications with Ruby on Rails, modern JavaScript, and a touch of AI." %>
        </p>

        <!-- Social links -->
        <% if social_links.any? %>
          <div class="flex items-center gap-3 mt-6">
            <% social_links.each do |link| %>
              <a href="<%= link.url %>" target="<%= link.url.start_with?('tel:') ? '_self' : '_blank' %>" rel="noopener"
                 class="w-9 h-9 rounded-xl bg-surface-900 flex items-center justify-center text-surface-400 hover:text-white hover:bg-surface-800 transition-all duration-200" aria-label="<%= link.platform.titleize %>">
                <%= link.icon_svg %>
              </a>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-3">
        <h3 class="text-xs font-mono text-surface-500 uppercase tracking-[0.15em] mb-5">Navigation</h3>
        <ul class="space-y-3">
          <li><%= link_to "Home", root_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
          <li><%= link_to "About", about_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
          <li><%= link_to "Projects", projects_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
          <li><%= link_to "Services", services_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
          <li><%= link_to "Blog", blog_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
          <li><%= link_to "Experience", experience_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
          <li><%= link_to "Contact", contact_path, class: "text-sm text-surface-400 hover:text-white transition-colors duration-200" %></li>
        </ul>
      </div>

      <!-- Resources & Contact -->
      <div class="md:col-span-4">
        <h3 class="text-xs font-mono text-surface-500 uppercase tracking-[0.15em] mb-5">Get in Touch</h3>

        <div class="space-y-3">
          <% email_link = social_links.find { |l| l.platform == "email" } %>
          <% footer_email = email_link ? email_link.url.gsub("mailto:", "") : (profile&.email.presence || "wintan1418@gmail.com") %>
          <a href="mailto:<%= footer_email %>" class="flex items-center gap-3 text-sm text-surface-400 hover:text-white transition-colors duration-200">
            <svg class="w-4 h-4 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <%= footer_email %>
          </a>

          <% phone_link = social_links.find { |l| l.platform == "phone" } %>
          <% if phone_link %>
            <a href="<%= phone_link.url %>" class="flex items-center gap-3 text-sm text-surface-400 hover:text-white transition-colors duration-200">
              <svg class="w-4 h-4 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <%= phone_link.url.gsub("tel:", "") %>
            </a>
          <% end %>

          <% whatsapp_link = social_links.find { |l| l.platform == "whatsapp" } %>
          <% if whatsapp_link %>
            <a href="<%= whatsapp_link.url %>" target="_blank" rel="noopener" class="flex items-center gap-3 text-sm text-surface-400 hover:text-white transition-colors duration-200">
              <svg class="w-4 h-4 text-surface-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          <% end %>

          <div class="flex items-center gap-3 text-sm text-surface-400">
            <svg class="w-4 h-4 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            <%= profile&.location || "Lagos, Nigeria" %>
          </div>
        </div>

        <div class="mt-6 pt-5 border-t border-surface-800/50">
          <h3 class="text-xs font-mono text-surface-500 uppercase tracking-[0.15em] mb-3">Resources</h3>
          <div class="flex flex-wrap gap-2">
            <% github_link = social_links.find { |l| l.platform == "github" } %>
            <% if github_link %>
              <a href="<%= github_link.url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-surface-900 text-xs text-surface-400 hover:text-white hover:bg-surface-800 transition-all duration-200">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
            <% end %>
            <%= link_to contact_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-surface-900 text-xs text-surface-400 hover:text-white hover:bg-surface-800 transition-all duration-200" do %>
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              Hire Me
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Terminal-style bottom bar -->
    <div class="mt-14 pt-6 border-t border-surface-800/50">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500/60"></span>
          </div>
          <p class="text-xs text-surface-500 font-mono">
            <span class="text-primary-400">~</span> &copy; <%= Date.current.year %> <%= profile&.full_name || "Oluwadare Juwon" %> <span class="text-surface-600">|</span> All rights reserved
          </p>
        </div>
        <p class="text-xs text-surface-500 font-mono flex items-center gap-1.5">
          Developed & built by
          <span class="text-white font-medium"><%= profile&.full_name || "Oluwadare Juwon" %></span>
          with
          <span class="text-red-400 font-medium">Ruby on Rails</span>
        </p>
      </div>
    </div>
  </div>
</footer>
