<h2>New Contact Message</h2>

<table style="width: 100%; border-collapse: collapse; margin-top: 16px;">
  <tr>
    <td style="padding: 8px 12px; font-weight: bold; color: #666; width: 120px;">Name</td>
    <td style="padding: 8px 12px;"><%= @contact.name %></td>
  </tr>
  <tr>
    <td style="padding: 8px 12px; font-weight: bold; color: #666;">Email</td>
    <td style="padding: 8px 12px;"><%= mail_to @contact.email %></td>
  </tr>
  <% if @contact.company.present? %>
    <tr>
      <td style="padding: 8px 12px; font-weight: bold; color: #666;">Company</td>
      <td style="padding: 8px 12px;"><%= @contact.company %></td>
    </tr>
  <% end %>
  <% if @contact.budget_range.present? %>
    <tr>
      <td style="padding: 8px 12px; font-weight: bold; color: #666;">Budget</td>
      <td style="padding: 8px 12px;"><%= @contact.budget_range %></td>
    </tr>
  <% end %>
  <% if @contact.subject.present? %>
    <tr>
      <td style="padding: 8px 12px; font-weight: bold; color: #666;">Subject</td>
      <td style="padding: 8px 12px;"><%= @contact.subject %></td>
    </tr>
  <% end %>
</table>

<div style="margin-top: 24px; padding: 16px; background: #f5f5f5; border-radius: 8px;">
  <p style="margin: 0; white-space: pre-wrap;"><%= @contact.message %></p>
</div>

<p style="margin-top: 24px; color: #888; font-size: 12px;">
  Received on <%= Time.current.strftime("%B %d, %Y at %I:%M %p") %>
</p>
